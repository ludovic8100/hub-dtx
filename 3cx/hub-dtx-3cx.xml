<?xml version="1.0" encoding="utf-8"?>
<Crm xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Country="BE" Name="Hub DTX" Version="4">
  <Number Prefix="AsIs" MaxLength="" />
  <Connection MaxConcurrentRequests="8" />
  <Parameters>
    <Parameter Name="ApiKey"  Type="String" Editor="String" Title="Cle API Hub" />
    <Parameter Name="BaseUrl" Type="String" Editor="String" Title="URL du Hub" />
  </Parameters>
  <Scenarios>
    <!-- 1) Lookup. [Number] transmis brut : la normalisation E.164 est faite cote Hub. -->
    <Scenario Id="" Type="REST">
      <Request Url="[BaseUrl]/api/3cx/lookup?number=[Number]&amp;key=[ApiKey]" MessagePasses="0" RequestEncoding="UrlEncoded" RequestType="Get" ResponseType="Json" />
      <Rules>
        <Rule Type="Any">contacts</Rule>
      </Rules>
      <Variables>
        <Variable Name="fn"  Path="contacts.firstName" />
        <Variable Name="ln"  Path="contacts.lastName" />
        <Variable Name="mob" Path="contacts.phoneMobile" />
        <Variable Name="ml"  Path="contacts.email" />
        <Variable Name="url" Path="contacts.url" />
      </Variables>
      <Outputs AllowEmpty="false">
        <Output Type="FirstName"   Passes="0" Value="[fn]" />
        <Output Type="LastName"    Passes="0" Value="[ln]" />
        <Output Type="Email"       Passes="0" Value="[ml]" />
        <Output Type="PhoneMobile" Passes="0" Value="[mob]" />
        <Output Type="ContactUrl"  Passes="0" Value="[url]" />
      </Outputs>
    </Scenario>
    <!-- 2) Journalisation d'appel (ReportCall). Pas de Number.Replace. -->
    <Scenario Id="ReportCall" Type="REST">
      <Request Url="[BaseUrl]/api/3cx/call?key=[ApiKey]" MessagePasses="0" RequestContentType="application/json" RequestEncoding="UrlEncoded" RequestType="Post" ResponseType="Json" Message="{ &quot;callType&quot;: ^^[CallType]^^, &quot;number&quot;: ^^[Number]^^, &quot;name&quot;: ^^[Name]^^, &quot;agent&quot;: ^^[Agent]^^, &quot;duration&quot;: ^^[Duration]^^, &quot;start&quot;: ^^[CallStartTimeUTC]^^ }" />
    </Scenario>
  </Scenarios>
</Crm>
